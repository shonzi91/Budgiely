<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!--
    FinApp is a standalone, privacy-first app and does NOT use the corporate Proget feed.
    We clear inherited sources (which otherwise time out) and restore from nuget.org only.
  -->
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
</configuration>
