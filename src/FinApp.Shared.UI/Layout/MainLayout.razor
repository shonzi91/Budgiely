@inherits LayoutComponentBase
@implements IDisposable
@inject AuthState Auth
@inject BudgetingState State
@inject Localizer Loc

<div class="app-shell">
    @if (Auth.IsAuthenticated)
    {
        <header class="app-bar">
            <span class="brand">FinApp</span>
            <span class="appbar-user">
                <span class="lang">
                    <button class="flag @(Loc.Culture == "en" ? "active" : "")" title="English" @onclick='() => SetLang("en")'>🇬🇧</button>
                    <button class="flag @(Loc.Culture == "bg" ? "active" : "")" title="Български" @onclick='() => SetLang("bg")'>🇧🇬</button>
                </span>
                <span class="user">@Loc["Hello,"] @Auth.CurrentUser!.Username</span>
                <button class="link" @onclick="SignOut">@Loc["Sign out"]</button>
            </span>
        </header>
    }
    <main class="app-body">
        @if (!_restored)
        {
            <p class="loading">@Loc["Loading…"]</p>
        }
        else if (!Auth.IsAuthenticated)
        {
            <AuthPanel />
        }
        else
        {
            @Body
        }
    </main>
</div>

@code {
    private bool _restored;

    protected override async Task OnInitializedAsync()
    {
        Auth.Changed += OnChanged;
        Loc.Changed += OnChanged;
        await Loc.InitializeAsync();
        try { await Auth.TryRestoreAsync(); }
        catch { /* server unreachable on startup — fall through to the sign-in screen */ }
        _restored = true;
    }

    private void OnChanged() => InvokeAsync(StateHasChanged);

    private async Task SetLang(string culture) => await Loc.SetCultureAsync(culture);

    private async Task SignOut()
    {
        await State.ResetAsync();
        await Auth.SignOutAsync();
    }

    public void Dispose()
    {
        Auth.Changed -= OnChanged;
        Loc.Changed -= OnChanged;
    }
}
