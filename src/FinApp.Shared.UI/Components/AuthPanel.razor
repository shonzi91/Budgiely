@inject AuthState Auth
@inject Localizer Loc
@implements IDisposable

<div class="auth">
    <div class="auth-lang">
        <button class="flag @(Loc.Culture == "en" ? "active" : "")" title="English" @onclick='() => Loc.SetCultureAsync("en")'>🇬🇧</button>
        <button class="flag @(Loc.Culture == "bg" ? "active" : "")" title="Български" @onclick='() => Loc.SetCultureAsync("bg")'>🇧🇬</button>
    </div>
    <h1 class="auth-brand"><span class="auth-logo"><BudgieLogo /></span> Budgiely</h1>
    <p class="auth-slogan">@Loc["Budget like a budgie."]</p>
    <p class="hint">@Loc["Private, shared budgeting. Sign in or create an account to begin."]</p>

    <div class="auth-tabs">
        <button class="tab @(_mode == Mode.Login ? "active" : "")" @onclick="() => Switch(Mode.Login)">@Loc["Sign in"]</button>
        <button class="tab @(_mode == Mode.Register ? "active" : "")" @onclick="() => Switch(Mode.Register)">@Loc["Create account"]</button>
    </div>

    @if (_error is not null)
    {
        <div class="alert warn-bg">@_error</div>
    }

    @if (_mode == Mode.Login)
    {
        <label>@Loc["Username or email"] <input type="text" placeholder="@Loc["you@example.com or username"]" autocomplete="username" @bind="_identifier" @bind:event="oninput" /></label>
        <label>@Loc["Password"] <input type="password" placeholder="@Loc["Your password"]" autocomplete="current-password" @bind="_password" @bind:event="oninput" @onkeydown="OnKey" /></label>
        <button class="primary" @onclick="SignIn" disabled="@(_busy || string.IsNullOrWhiteSpace(_identifier) || string.IsNullOrEmpty(_password))">
            @(_busy ? Loc["Signing in…"] : Loc["Sign in"])
        </button>
    }
    else
    {
        <label>@Loc["Username"] <input type="text" placeholder="@Loc["Pick a username"]" autocomplete="username" @bind="_username" @bind:event="oninput" /></label>
        <label>@Loc["Email"] <input type="email" placeholder="you@example.com" autocomplete="email" @bind="_email" @bind:event="oninput" /></label>
        <label>@Loc["Password"] <input type="password" placeholder="@Loc["At least 8 characters"]" autocomplete="new-password" @bind="_password" @bind:event="oninput" @onkeydown="OnKey" /></label>
        <button class="primary" @onclick="Register" disabled="@(_busy || !CanRegister)">
            @(_busy ? Loc["Creating…"] : Loc["Create account"])
        </button>
        <small class="hint">@Loc["Password must be at least 8 characters."]</small>
    }
</div>

@code {
    private enum Mode { Login, Register }
    private Mode _mode = Mode.Login;
    private string _identifier = "", _username = "", _email = "", _password = "";
    private string? _error;
    private bool _busy;

    private bool CanRegister =>
        !string.IsNullOrWhiteSpace(_username) && !string.IsNullOrWhiteSpace(_email) && _password.Length >= 8;

    protected override void OnInitialized() => Loc.Changed += OnLocChanged;
    private void OnLocChanged() => InvokeAsync(StateHasChanged);
    public void Dispose() => Loc.Changed -= OnLocChanged;

    private void Switch(Mode mode) { _mode = mode; _error = null; }

    private Task OnKey(KeyboardEventArgs e) =>
        e.Key == "Enter" ? (_mode == Mode.Login ? SignIn() : Register()) : Task.CompletedTask;

    private Task SignIn() => Run(() => Auth.LogInAsync(_identifier, _password));
    private Task Register() => Run(() => Auth.RegisterAsync(_username, _email, _password));

    private async Task Run(Func<Task> action)
    {
        if (_busy) return;
        _error = null;
        _busy = true;
        try { await action(); }
        catch (HttpRequestException) { _error = "Couldn’t reach the server. Check your connection and try again."; }
        catch (Exception ex) { _error = ex.Message; }
        finally { _busy = false; }
    }
}
