@inject BudgetingState State
@inject Localizer Loc

@if (State.PendingInvitationCount > 0)
{
    <section class="invites">
        <div class="invites-head">
            <span class="invites-icon">✉️</span>
            <div class="invites-title">
                <h3>@Loc["You’re invited"]</h3>
                <p>@State.PendingInvitationCount @(State.PendingInvitationCount == 1 ? Loc["pending invitation"] : Loc["pending invitations"])</p>
            </div>
        </div>

        <ul class="invite-list">
            @foreach (var inv in State.PendingInvitations)
            {
                <li class="invite">
                    <span class="invite-avatar">@Initials(inv.InvitedByUsername)</span>
                    <span class="invite-text">
                        <strong>@inv.InvitedByUsername</strong> @Loc["invited you to"] <strong>@inv.AccountName</strong>
                    </span>
                    <span class="invite-actions">
                        <button class="invite-accept" @onclick="() => Accept(inv.Id)">✓ @Loc["Accept"]</button>
                        <button class="invite-decline" @onclick="() => Decline(inv.Id)">@Loc["Decline"]</button>
                    </span>
                </li>
            }
        </ul>

        @if (_error is not null)
        {
            <div class="invite-error">@_error</div>
        }
    </section>
}

@code {
    private string? _error;

    private static string Initials(string name)
    {
        name = name?.Trim() ?? "";
        if (name.Length == 0) return "?";
        var parts = name.Split(new[] { ' ', '.', '_', '-' }, StringSplitOptions.RemoveEmptyEntries);
        var s = parts.Length >= 2 ? $"{parts[0][0]}{parts[1][0]}" : name[..Math.Min(2, name.Length)];
        return s.ToUpperInvariant();
    }

    private Task Accept(Guid id) => Run(() => State.AcceptInvitation(id));
    private Task Decline(Guid id) => Run(() => State.DeclineInvitation(id));

    private async Task Run(Func<Task> action)
    {
        _error = null;
        try { await action(); }
        catch (Exception ex) { _error = ex.Message; }
    }
}
